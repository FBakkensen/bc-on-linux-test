# Build outputs
.build/
*.app

# AL symbol cache (shared by app/ and test/ via al.packageCachePath)
/.alpackages/

# AL / VS Code AL extension generated
.vscode/.alcache/
.vscode/.alpackages/
**/.snapshots/
**/rad.json

# al-compile (al-smart-compile) per-project diagnostics
**/.dev/

# Upstream BC runtime checkout — separate clone of StefanMaron/MsDyn365Bc.On.Linux
bc-linux/

# Copilot Coding Agent CI runtime state (populated by .github/workflows/copilot-setup-steps.yml)
.bc-artifacts/
.bc-cache/
.symbols/
.logs/

# Reviewer-pack generated artifacts (regenerate via docs/reviewer-pack/README.md)
docs/reviewer-pack/diagrams/*.png
docs/reviewer-pack/*.pdf

# Python (planning-optimizer/ sibling package per ADR 0009)
planning-optimizer/.venv/
.venv-python-check/
**/__pycache__/
**/*.egg-info/
**/.pytest_cache/
**/.ipynb_checkpoints/
**/.mypy_cache/
**/.ruff_cache/
**/.coverage
**/htmlcov/

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
